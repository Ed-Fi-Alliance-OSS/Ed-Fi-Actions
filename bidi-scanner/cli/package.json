  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@edfi/bidi-scanner-lib": "file:../lib",
    "glob": "^13.0.0",
    "triple-beam": "^1.4.0",
    "winston": "^3.19.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
