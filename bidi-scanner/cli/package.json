    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --ci --config ./jest.ci-config.json",
    "lint": "npx eslint **/*.mjs",
    "lint:fix": "npx eslint **/*.mjs --fix"
  },
  "repository": {
